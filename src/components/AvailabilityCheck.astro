---
// Componente de formulario de disponibilidad con envío a WhatsApp
// Props que puede recibir desde la página que lo usa
export interface Props {
	phoneNumber?: string; // Número de teléfono del hotel (con código país, sin '+' ni espacios)
	hotelName?: string; // Nombre del hotel para personalizar el mensaje
}

const { phoneNumber = "", hotelName = "Hotel" } = Astro.props;
---

<div class="availability-form bg-white rounded-xl shadow-lg relative z-10">
	<!-- Eliminamos action y method, ahora se maneja con JavaScript -->
	<div class="w-full" id="availability-check-form">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0">
			<!-- Date Picker -->
			<div class="p-6 border-r border-gray-100">
				<label class="block text-sm font-medium text-gray-700 mb-1"
					>Checkin - Checkout</label
				>
				<div class="relative">
					<input
						id="datepicker"
						type="text"
						placeholder="Elegir fechas"
						class="w-full p-3 pl-12 border border-gray-300 rounded-lg appearance-none focus:ring-2 focus:ring-primary focus:border-transparent availability-form-field cursor-pointer"
						readonly
					/>
					<span
						id="toggleDatepicker"
						class="absolute inset-y-0 flex h-12 w-12 items-center justify-center text-gray-500"
					>
						<svg
							width="21"
							height="20"
							viewBox="0 0 21 20"
							fill="none"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								d="M18 3.3125H16.3125V2.625C16.3125 2.25 16 1.90625 15.5937 1.90625C15.1875 1.90625 14.875 2.21875 14.875 2.625V3.28125H6.09375V2.625C6.09375 2.25 5.78125 1.90625 5.375 1.90625C4.96875 1.90625 4.65625 2.21875 4.65625 2.625V3.28125H3C1.9375 3.28125 1.03125 4.15625 1.03125 5.25V16.125C1.03125 17.1875 1.90625 18.0938 3 18.0938H18C19.0625 18.0938 19.9687 17.2187 19.9687 16.125V5.25C19.9687 4.1875 19.0625 3.3125 18 3.3125ZM3 4.71875H4.6875V5.34375C4.6875 5.71875 5 6.0625 5.40625 6.0625C5.8125 6.0625 6.125 5.75 6.125 5.34375V4.71875H14.9687V5.34375C14.9687 5.71875 15.2812 6.0625 15.6875 6.0625C16.0937 6.0625 16.4062 5.75 16.4062 5.34375V4.71875H18C18.3125 4.71875 18.5625 4.96875 18.5625 5.28125V7.34375H2.46875V5.28125C2.46875 4.9375 2.6875 4.71875 3 4.71875ZM18 16.6562H3C2.6875 16.6562 2.4375 16.4062 2.4375 16.0937V8.71875H18.5312V16.125C18.5625 16.4375 18.3125 16.6562 18 16.6562Z"
								fill="currentColor"></path>
							<path
								d="M9.5 9.59375H8.8125C8.625 9.59375 8.5 9.71875 8.5 9.90625V10.5938C8.5 10.7812 8.625 10.9062 8.8125 10.9062H9.5C9.6875 10.9062 9.8125 10.7812 9.8125 10.5938V9.90625C9.8125 9.71875 9.65625 9.59375 9.5 9.59375Z"
								fill="currentColor"></path>
							<path
								d="M12.3438 9.59375H11.6562C11.4687 9.59375 11.3438 9.71875 11.3438 9.90625V10.5938C11.3438 10.7812 11.4687 10.9062 11.6562 10.9062H12.3438C12.5312 10.9062 12.6562 10.7812 12.6562 10.5938V9.90625C12.6562 9.71875 12.5312 9.59375 12.3438 9.59375Z"
								fill="currentColor"></path>
							<path
								d="M15.1875 9.59375H14.5C14.3125 9.59375 14.1875 9.71875 14.1875 9.90625V10.5938C14.1875 10.7812 14.3125 10.9062 14.5 10.9062H15.1875C15.375 10.9062 15.5 10.7812 15.5 10.5938V9.90625C15.5 9.71875 15.375 9.59375 15.1875 9.59375Z"
								fill="currentColor"></path>
							<path
								d="M6.5 12H5.8125C5.625 12 5.5 12.125 5.5 12.3125V13C5.5 13.1875 5.625 13.3125 5.8125 13.3125H6.5C6.6875 13.3125 6.8125 13.1875 6.8125 13V12.3125C6.8125 12.125 6.65625 12 6.5 12Z"
								fill="currentColor"></path>
							<path
								d="M9.5 12H8.8125C8.625 12 8.5 12.125 8.5 12.3125V13C8.5 13.1875 8.625 13.3125 8.8125 13.3125H9.5C9.6875 13.3125 9.8125 13.1875 9.8125 13V12.3125C9.8125 12.125 9.65625 12 9.5 12Z"
								fill="currentColor"></path>
							<path
								d="M12.3438 12H11.6562C11.4687 12 11.3438 12.125 11.3438 12.3125V13C11.3438 13.1875 11.4687 13.3125 11.6562 13.3125H12.3438C12.5312 13.3125 12.6562 13.1875 12.6562 13V12.3125C12.6562 12.125 12.5312 12 12.3438 12Z"
								fill="currentColor"></path>
							<path
								d="M15.1875 12H14.5C14.3125 12 14.1875 12.125 14.1875 12.3125V13C14.1875 13.1875 14.3125 13.3125 14.5 13.3125H15.1875C15.375 13.3125 15.5 13.1875 15.5 13V12.3125C15.5 12.125 15.375 12 15.1875 12Z"
								fill="currentColor"></path>
							<path
								d="M6.5 14.4062H5.8125C5.625 14.4062 5.5 14.5312 5.5 14.7187V15.4062C5.5 15.5938 5.625 15.7188 5.8125 15.7188H6.5C6.6875 15.7188 6.8125 15.5938 6.8125 15.4062V14.7187C6.8125 14.5312 6.65625 14.4062 6.5 14.4062Z"
								fill="currentColor"></path>
							<path
								d="M9.5 14.4062H8.8125C8.625 14.4062 8.5 14.5312 8.5 14.7187V15.4062C8.5 15.5938 8.625 15.7188 8.8125 15.7188H9.5C9.6875 15.7188 9.8125 15.5938 9.8125 15.4062V14.7187C9.8125 14.5312 9.65625 14.4062 9.5 14.4062Z"
								fill="currentColor"></path>
							<path
								d="M12.3438 14.4062H11.6562C11.4687 14.4062 11.3438 14.5312 11.3438 14.7187V15.4062C11.3438 15.5938 11.4687 15.7188 11.6562 15.7188H12.3438C12.5312 15.7188 12.6562 15.5938 12.6562 15.4062V14.7187C12.6562 14.5312 12.5312 14.4062 12.3438 14.4062Z"
								fill="currentColor"></path>
						</svg>
					</span>
				</div>

				<!-- Contenedor del calendario -->
				<div
					id="datepicker-container"
					class="absolute z-50 mt-2 hidden w-full md:w-auto bottom-0"
				>
					<div
						class="w-full flex-col rounded-lg border border-gray-200 bg-white px-4 py-6 shadow-lg sm:px-6 sm:py-[30px]"
					>
						<div class="flex items-center justify-between pb-2">
							<p
								id="currentMonth"
								class="text-base font-medium text-gray-800"
							>
								August 2023
							</p>
							<div
								class="flex items-center justify-end space-x-2"
							>
								<span
									id="prevMonth"
									class="flex h-8 w-8 cursor-pointer items-center justify-center rounded border border-gray-300 bg-gray-100 text-gray-700 hover:border-primary hover:bg-primary hover:text-white"
								>
									<svg
										width="14"
										height="14"
										viewBox="0 0 16 16"
										fill="none"
										xmlns="http://www.w3.org/2000/svg"
										class="fill-current"
									>
										<path
											d="M10.825 14.325C10.675 14.325 10.525 14.275 10.425 14.15L4.77501 8.40002C4.55001 8.17502 4.55001 7.82502 4.77501 7.60002L10.425 1.85002C10.65 1.62502 11 1.62502 11.225 1.85002C11.45 2.07502 11.45 2.42502 11.225 2.65002L5.97501 8.00003L11.25 13.35C11.475 13.575 11.475 13.925 11.25 14.15C11.1 14.25 10.975 14.325 10.825 14.325Z"
										></path>
									</svg>
								</span>
								<span
									id="nextMonth"
									class="flex h-8 w-8 cursor-pointer items-center justify-center rounded border border-gray-300 bg-gray-100 text-gray-700 hover:border-primary hover:bg-primary hover:text-white"
								>
									<svg
										width="14"
										height="14"
										viewBox="0 0 16 16"
										fill="none"
										xmlns="http://www.w3.org/2000/svg"
										class="fill-current"
									>
										<path
											d="M5.17501 14.325C5.02501 14.325 4.90001 14.275 4.77501 14.175C4.55001 13.95 4.55001 13.6 4.77501 13.375L10.025 8.00003L4.77501 2.65002C4.55001 2.42502 4.55001 2.07502 4.77501 1.85002C5.00001 1.62502 5.35001 1.62502 5.57501 1.85002L11.225 7.60002C11.45 7.82502 11.45 8.17502 11.225 8.40002L5.57501 14.15C5.47501 14.25 5.32501 14.325 5.17501 14.325Z"
										></path>
									</svg>
								</span>
							</div>
						</div>
						<div
							class="grid grid-cols-7 pb-2 pt-4 text-sm font-normal text-gray-500"
						>
							<span
								class="flex h-[38px] w-[38px] items-center justify-center"
								>Mo</span
							>
							<span
								class="flex h-[38px] w-[38px] items-center justify-center"
								>Tu</span
							>
							<span
								class="flex h-[38px] w-[38px] items-center justify-center"
								>We</span
							>
							<span
								class="flex h-[38px] w-[38px] items-center justify-center"
								>Th</span
							>
							<span
								class="flex h-[38px] w-[38px] items-center justify-center"
								>Fr</span
							>
							<span
								class="flex h-[38px] w-[38px] items-center justify-center"
								>Sa</span
							>
							<span
								class="flex h-[38px] w-[38px] items-center justify-center"
								>Su</span
							>
						</div>

						<div
							id="days-container"
							class="grid grid-cols-7 text-sm font-medium text-gray-800"
						>
							<!-- Los días se generan con JS -->
						</div>

						<div
							class="flex items-center justify-center space-x-3 pt-4 sm:space-x-4"
						>
							<input
								type="date"
								id="startDate"
								name="start_date"
								class="h-9 rounded border border-gray-300 bg-transparent px-3 text-sm text-gray-700 hover:border-primary focus:border-primary focus:outline-none"
							/>
							<input
								type="date"
								id="endDate"
								name="end_date"
								class="h-9 rounded border border-gray-300 bg-transparent px-3 text-sm text-gray-700 hover:border-primary focus:border-primary focus:outline-none"
							/>
						</div>
					</div>
				</div>
			</div>

			<!-- Guests -->
			<div class="p-6 border-r border-gray-100">
				<label class="block text-sm font-medium text-gray-700 mb-1"
					>Huéspedes</label
				>
				<div class="relative">
					<select
						id="guestCountSelect"
						name="guest_count"
						class="w-full p-3 border border-gray-300 rounded-lg appearance-none focus:ring-2 focus:ring-primary focus:border-transparent availability-form-field bg-white"
					>
						<option value="1">1 persona</option>
						<option value="2" selected>2 personas</option>
						<option value="3">3 personas</option>
					</select>
					<div
						class="absolute inset-y-0 right-3 flex items-center pointer-events-none"
					>
						<i class="fas fa-chevron-down text-gray-400"></i>
					</div>
				</div>
			</div>

			<!-- Botón de envío (WhatsApp) -->
			<div class="p-6 pt-0 md:pt-6 lg:flex items-end hidden">
				<button
					id="whatsappButton"
					type="button"
					class="w-full bg-primary hover:bg-primary-dark text-white font-semibold py-3 px-6 rounded-lg transition duration-300 flex items-center justify-center"
				>
					<i class="fa-brands fa-whatsapp mr-2"></i> consultar disponibilidad
				</button>
			</div>
		</div>
		<div class="p-6 pt-0 md:pt-6 block lg:hidden">
			<button
				id="whatsappButtonMobile"
				type="button"
				class="w-full bg-primary hover:bg-primary-dark text-white font-semibold py-3 px-6 rounded-lg transition duration-300 flex items-center justify-center"
			>
				<i class="fa-brands fa-whatsapp mr-2"></i> consultar disponibilidad
			</button>
		</div>
	</div>
</div>

<style>
	/* Ajustes para el datepicker */
	#datepicker-container {
		width: 100%;
		min-width: 280px;
		left: 0;
	}
	@media (min-width: 640px) {
		#datepicker-container {
			width: auto;
			min-width: 360px;
			left: auto;
		}
	}
	input[type="date"]::-webkit-calendar-picker-indicator {
		opacity: 0.5;
		cursor: pointer;
	}
	select {
		-webkit-appearance: none;
		-moz-appearance: none;
		appearance: none;
	}
</style>

<script define:vars={{ phoneNumber, hotelName }}>
	(function () {
		// Elementos del DOM
		const datepicker = document.getElementById("datepicker");
		const datepickerContainer = document.getElementById(
			"datepicker-container",
		);
		const daysContainer = document.getElementById("days-container");
		const currentMonthElement = document.getElementById("currentMonth");
		const prevMonthButton = document.getElementById("prevMonth");
		const nextMonthButton = document.getElementById("nextMonth");
		const toggleDatepicker = document.getElementById("toggleDatepicker");
		const startDateInput = document.getElementById("startDate");
		const endDateInput = document.getElementById("endDate");
		const guestCountSelect = document.getElementById("guestCountSelect");
		const whatsappButton = document.getElementById("whatsappButton");
		const whatsappButtonMobile = document.getElementById(
			"whatsappButtonMobile",
		);

		// Datos del hotel desde props (inyectados como variables globales)
		// const phoneNumber = "{phoneNumber}";
		// const hotelName = "{hotelName}";

		let currentDate = new Date();
		let selectedStartDate = null;
		let selectedEndDate = null;

		// Funciones auxiliares
		function formatDate(date) {
			const d = new Date(date);
			const year = d.getFullYear();
			const month = String(d.getMonth() + 1).padStart(2, "0");
			const day = String(d.getDate()).padStart(2, "0");
			return `${year}-${month}-${day}`;
		}

		function formatDateForMessage(dateStr) {
			// Convierte YYYY-MM-DD a DD/MM/YYYY para el mensaje
			if (!dateStr) return "";
			const [year, month, day] = dateStr.split("-");
			return `${day}/${month}/${year}`;
		}

		function updateInputs() {
			if (selectedStartDate && selectedEndDate) {
				datepicker.value = `${selectedStartDate} - ${selectedEndDate}`;
				startDateInput.value = selectedStartDate;
				endDateInput.value = selectedEndDate;
			} else if (selectedStartDate) {
				datepicker.value = selectedStartDate;
				startDateInput.value = selectedStartDate;
				endDateInput.value = "";
			} else {
				datepicker.value = "";
				startDateInput.value = "";
				endDateInput.value = "";
			}
		}

		function renderCalendar() {
			const year = currentDate.getFullYear();
			const month = currentDate.getMonth();

			currentMonthElement.textContent = currentDate.toLocaleDateString(
				"es-ES",
				{ month: "long", year: "numeric" },
			);

			daysContainer.innerHTML = "";
			const firstDayOfMonth = new Date(year, month, 1).getDay();
			const daysInMonth = new Date(year, month + 1, 0).getDate();

			let adjustedFirstDay =
				firstDayOfMonth === 0 ? 6 : firstDayOfMonth - 1;

			for (let i = 0; i < adjustedFirstDay; i++) {
				daysContainer.innerHTML += `<div></div>`;
			}

			for (let i = 1; i <= daysInMonth; i++) {
				const day = new Date(year, month, i);
				const dayString = formatDate(day);
				let className =
					"flex h-[46px] w-[46px] items-center justify-center rounded-full hover:bg-gray-200 mb-2 cursor-pointer";

				if (
					selectedStartDate === dayString &&
					selectedEndDate === dayString
				) {
					className += " bg-primary text-white rounded-full";
				} else if (selectedStartDate === dayString) {
					className +=
						" bg-primary text-white rounded-r-none rounded-l-full";
				} else if (selectedEndDate === dayString) {
					className +=
						" bg-primary text-white rounded-l-none rounded-r-full";
				} else if (
					selectedStartDate &&
					selectedEndDate &&
					dayString > selectedStartDate &&
					dayString < selectedEndDate
				) {
					className += " bg-gray-200 rounded-none";
				}

				daysContainer.innerHTML += `<div class="${className}" data-date="${dayString}">${i}</div>`;
			}

			document
				.querySelectorAll("#days-container div[data-date]")
				.forEach((day) => {
					day.addEventListener("click", function (event) {
						event.stopPropagation();
						const selectedDay = this.dataset.date;

						if (
							!selectedStartDate ||
							(selectedStartDate && selectedEndDate)
						) {
							selectedStartDate = selectedDay;
							selectedEndDate = null;
						} else {
							if (selectedDay < selectedStartDate) {
								selectedEndDate = selectedStartDate;
								selectedStartDate = selectedDay;
							} else {
								selectedEndDate = selectedDay;
							}
						}

						updateInputs();
						renderCalendar();
					});
				});
		}

		function toggleCalendar() {
			datepickerContainer.classList.toggle("hidden");
			if (!datepickerContainer.classList.contains("hidden")) {
				renderCalendar();
			}
		}

		// Función para enviar mensaje por WhatsApp
		function sendWhatsAppMessage() {
			// Validar que haya fechas seleccionadas
			if (!selectedStartDate || !selectedEndDate) {
				alert(
					"Por favor selecciona las fechas de check-in y check-out.",
				);
				return;
			}
			// console.log(phoneNumber);

			const startFormatted = formatDateForMessage(selectedStartDate);
			const endFormatted = formatDateForMessage(selectedEndDate);
			const guestCount =
				guestCountSelect.options[guestCountSelect.selectedIndex]
					?.text || "2 personas";

			const message = `Hola, quisiera consultar disponibilidad para ${hotelName} del ${startFormatted} al ${endFormatted} para ${guestCount}. Gracias.`;
			const encodedMessage = encodeURIComponent(message);
			const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodedMessage}`;
			window.open(whatsappUrl, "_blank");
		}

		// Event listeners
		datepicker.addEventListener("click", toggleCalendar);
		toggleDatepicker.addEventListener("click", toggleCalendar);

		// Cerrar calendario al hacer clic fuera
		document.addEventListener("click", function (event) {
			if (
				!datepickerContainer.contains(event.target) &&
				event.target !== datepicker &&
				event.target !== toggleDatepicker &&
				!toggleDatepicker.contains(event.target)
			) {
				datepickerContainer.classList.add("hidden");
			}
		});

		prevMonthButton.addEventListener("click", function () {
			currentDate.setMonth(currentDate.getMonth() - 1);
			renderCalendar();
		});

		nextMonthButton.addEventListener("click", function () {
			currentDate.setMonth(currentDate.getMonth() + 1);
			renderCalendar();
		});

		// Botones WhatsApp
		if (whatsappButton)
			whatsappButton.addEventListener("click", sendWhatsAppMessage);
		if (whatsappButtonMobile)
			whatsappButtonMobile.addEventListener("click", sendWhatsAppMessage);

		// Inicializar fechas por defecto (hoy +1 y +2)
		const today = new Date();
		const tomorrow = new Date(today);
		tomorrow.setDate(today.getDate() + 1);
		const twoDaysLater = new Date(today);
		twoDaysLater.setDate(today.getDate() + 2);

		selectedStartDate = formatDate(tomorrow);
		selectedEndDate = formatDate(twoDaysLater);
		updateInputs();
		renderCalendar();
	})();
</script>
