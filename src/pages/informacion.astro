---
import Layout from "../layouts/Layout.astro";
import companyData from "../data/company.json";
import galleryImages from "../data/gallery.json";
---

<Layout
    description={`Conoce más sobre ${companyData.hotel_name} - Historia, ubicación y contacto`}
    company={companyData}
>
    <!-- Hero Section -->
    <section
        class="relative bg-cover bg-center h-96 flex items-center justify-center"
        style={`background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('images/frente.jpeg')`}
    >
        <div class="container mx-auto px-4 text-center text-white">
            <h1 class="text-4xl md:text-5xl font-bold mb-4">Sobre Nosotros</h1>
            <p class="text-xl md:text-2xl max-w-2xl mx-auto">
                {companyData.short_description}
            </p>
        </div>
    </section>

    <!-- Sobre el Hotel -->
    <section class="py-16 bg-white">
        <div class="container mx-auto px-4 max-w-5xl">
            <div class="text-center mb-12">
                <img
                    src={companyData.logo}
                    alt={`Logo ${companyData.hotel_name}`}
                    class="h-24 mx-auto mb-6"
                />
                <h2 class="text-3xl font-bold text-gray-800 mb-4">
                    {companyData.hotel_name}
                </h2>
                <div class="w-20 h-1 bg-primary mx-auto mb-8"></div>
            </div>

            <div
                class="prose prose-lg max-w-none text-gray-700 text-center"
                set:html={companyData.description}
            />
        </div>
    </section>

    <!-- Ubicación y Contacto -->
    <section class="py-16 bg-gray-50">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- Ubicación -->
                <div>
                    <h2 class="text-3xl font-bold text-gray-800 mb-6">
                        Ubicación
                    </h2>
                    <div class="bg-white p-6 rounded-lg shadow-md">
                        <div class="flex items-start mb-6">
                            <div class="text-primary text-xl mr-4">
                                <i class="fas fa-map-marker-alt"></i>
                            </div>
                            <div>
                                <h3 class="text-xl font-semibold mb-1">
                                    Dirección
                                </h3>
                                <p class="text-gray-600">
                                    {companyData.address}
                                </p>
                            </div>
                        </div>

                        <div class="mt-6">
                            <a
                                href={`https://maps.google.com/?q=${encodeURIComponent(companyData.address)}`}
                                target="_blank"
                                class="inline-flex items-center text-primary font-medium"
                            >
                                <i class="fas fa-directions mr-2"></i> Cómo llegar
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Contacto -->
                <div>
                    <h2 class="text-3xl font-bold text-gray-800 mb-6">
                        Contacto
                    </h2>
                    <div class="bg-white p-6 rounded-lg shadow-md">
                        <div class="mb-6">
                            <h3 class="text-xl font-semibold mb-4">
                                Formas de contactarnos
                            </h3>

                            <div class="space-y-4">
                                <div class="flex items-start">
                                    <div class="text-primary text-xl mr-4">
                                        <i class="fas fa-phone"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-medium">Teléfono</h4>
                                        <a
                                            href={`tel:${companyData.phone_number}`}
                                            class="text-gray-600 hover:text-primary"
                                        >
                                            {companyData.phone_number}
                                        </a>
                                    </div>
                                </div>

                                <div class="flex items-start">
                                    <div class="text-primary text-xl mr-4">
                                        <i class="fas fa-envelope"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-medium">Email</h4>
                                        <a
                                            href={`mailto:${companyData.email_address}`}
                                            class="text-gray-600 hover:text-primary"
                                        >
                                            {companyData.email_address}
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="pt-6 border-t border-gray-200">
                            <h3 class="text-xl font-semibold mb-4">
                                Síguenos en redes
                            </h3>
                            <div
                                class="flex space-x-4 justify-center md:justify-start"
                            >
                                {
                                    companyData.facebook_url && (
                                        <a
                                            href={companyData.facebook_url}
                                            target="_blank"
                                            class="text-gray-600 hover:text-primary text-2xl"
                                        >
                                            <i class="fab fa-facebook-f" />
                                        </a>
                                    )
                                }
                                {
                                    companyData.instagram_url && (
                                        <a
                                            href={companyData.instagram_url}
                                            target="_blank"
                                            class="text-gray-600 hover:text-primary text-2xl"
                                        >
                                            <i class="fab fa-instagram" />
                                        </a>
                                    )
                                }
                                {
                                    companyData.twitter_url && (
                                        <a
                                            href={companyData.twitter_url}
                                            target="_blank"
                                            class="text-gray-600 hover:text-primary text-2xl"
                                        >
                                            <i class="fab fa-x-twitter" />
                                        </a>
                                    )
                                }
                                {
                                    companyData.tiktok_url && (
                                        <a
                                            href={companyData.tiktok_url}
                                            target="_blank"
                                            class="text-gray-600 hover:text-primary text-2xl"
                                        >
                                            <i class="fab fa-tiktok" />
                                        </a>
                                    )
                                }
                                {
                                    companyData.phone_number && (
                                        <a
                                            href={`https://wa.me/${companyData.phone_number.replace(/[^0-9]/g, "")}`}
                                            target="_blank"
                                            class="text-gray-600 hover:text-primary text-2xl"
                                        >
                                            <i class="fab fa-whatsapp" />
                                        </a>
                                    )
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Galería de Habitaciones -->
    <section class="py-16 bg-white" id="gallery">
        <div class="container mx-auto px-4">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-gray-800 mb-4">
                    Nuestras Habitaciones
                </h2>
                <p class="text-gray-600 max-w-2xl mx-auto">
                    Descubre el confort y elegancia de nuestros espacios
                    cuidadosamente diseñados para tu comodidad.
                </p>
                <div class="w-20 h-1 bg-primary mx-auto mt-6"></div>
            </div>

            <!-- Galería Masonry con Tailwind columns -->
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
                {
                    galleryImages.map((image, idx) => (
                        <div class="break-inside-avoid group relative overflow-hidden rounded-lg shadow-md">
                            <img
                                src={image.image_medium}
                                alt={
                                    image.alt ||
                                    `Habitación ${companyData.hotel_name}`
                                }
                                class="w-full h-auto transition-transform duration-500 group-hover:scale-105"
                            />
                            <div class="absolute inset-0 group-hover:bg-black/30 transition-all duration-300 flex items-center justify-center">
                                <button
                                    onclick={`openImageModal('${image.image_large}')`}
                                    class="opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-300 text-white text-2xl bg-primary  rounded-full p-3 cursor-pointer"
                                >
                                    <i class="fas fa-search-plus" />
                                </button>
                            </div>
                        </div>
                    ))
                }
            </div>

            <div class="text-center mt-10">
                <a
                    href="/reservation"
                    class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold py-3 px-8 rounded-lg transition duration-300"
                >
                    Ver disponibilidad
                </a>
            </div>
        </div>

        <!-- Modal de imagen -->
        <div
            id="modalImage"
            class="fixed top-0 left-0 z-50 w-full h-full justify-center items-center bg-gray-900/90 hidden"
            onclick="closeImageModal()"
        >
            <div
                class="border rounded-xl bg-white p-3 flex justify-center items-center max-w-[90vw] max-h-[90vh]"
            >
                <img
                    id="modalImageSrc"
                    src=""
                    style="max-height: 80vh; width: auto; object-fit: contain;"
                />
            </div>
        </div>
    </section>

    <!-- Scripts específicos para esta página (usando slot extra_js) -->
    <script is:inline>
        function openImageModal(largeImageUrl) {
            const modal = document.getElementById("modalImage");
            const modalImg = document.getElementById("modalImageSrc");
            modalImg.src = largeImageUrl;
            modal.classList.remove("hidden");
            modal.classList.add("flex");

            // Prevenir scroll del body
            document.body.style.overflow = "hidden";
        }

        function closeImageModal() {
            const modal = document.getElementById("modalImage");
            modal.classList.add("hidden");
            modal.classList.add("flex");
            const modalImg = document.getElementById("modalImageSrc");
            modalImg.src = "";
            document.body.style.overflow = "";
        }

        // Cerrar con tecla ESC
        document.addEventListener("keydown", (event) => {
            const modal = document.getElementById("modalImage");
            if (!modal.classList.contains("hidden") && event.key === "Escape") {
                closeImageModal();
            }
        });
    </script>
</Layout>
